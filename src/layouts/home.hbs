<script>
  (function () {
    var siteUrl = '{{{site.url}}}';
    var cardLinks = {
      'card-cloud': siteUrl + '/cloud/latest',
      'card-software': siteUrl + '/software/latest',
      'card-mobile': siteUrl + '/mobile/latest',
      'card-developer': 'https://developers.thoughtspot.com/docs',
      'card-seekwell': siteUrl + '/seekwell',
      'card-agentspot': siteUrl + '/agentspot',
    };
    Object.keys(cardLinks).forEach(function (cls) {
      document.querySelectorAll('.' + cls).forEach(function (el) {
        var a = document.createElement('a');
        a.href = cardLinks[cls];
        a.className = el.className;
        while (el.firstChild) a.appendChild(el.firstChild);
        el.parentNode.replaceChild(a, el);
      });
    });

    // Generic custom cards — URL and label come from a link: macro inside the block
    document.querySelectorAll('.card-custom').forEach(function (el) {
      var innerLink = el.querySelector('a');
      if (!innerLink) return;
      var href = innerLink.href;
      var a = document.createElement('a');
      a.href = href;
      a.className = el.className;
      while (el.firstChild) a.appendChild(el.firstChild);
      el.parentNode.replaceChild(a, el);
      // Replace nested <a> with plain text to avoid invalid nested links
      var nested = a.querySelector('a');
      if (nested) {
        nested.parentNode.replaceChild(document.createTextNode(nested.textContent), nested);
      }
    });
  })();
</script>
