        visibility: visible!important;
    }

    .intercom-namespace .intercom-app .intercom-messenger-frame.show {
        transform: translateX(0)!important;
        box-shadow: rgba(9, 14, 21, 0.16) 0px 5px 40px 0px!important;
    }

    {{!-- Hide this element because it's used as a initializing animation for the messenger window and we're doing our own animation. --}}
    .intercom-messenger {
        display: none!important;
    }
</style>

<script>
    function onIntercomMessengerFrame(callback) {
        const selector = 'div.intercom-messenger-frame';
        // Fast path: already in DOM
        const existing = document.querySelector(selector);
        if (existing) {
            callback(existing);
            return () => { };
        }
        const obs = new MutationObserver((mutations) => {
            for (const { addedNodes } of mutations) {
                for (const node of addedNodes) {
                    if (node.nodeType !== 1) continue;
                    const found =
                        node.matches?.(selector) ||
                        node.querySelector?.(selector);
                    if (found) {
                        obs.disconnect();
                        callback(found);
                        return;
                    }
                }
            }
        });
        obs.observe(document.documentElement, {
            childList: true,
            subtree: true,
        });
        return () => obs.disconnect(); // cleanup if never found
    }

    onIntercomMessengerFrame((el) => {
        const messengerDiv = el

        setTimeout(() => {
            messengerDiv.classList.add('show');
        }, 10);

        const intercomLauncher = document.querySelector('.intercom-launcher-frame');

        // Listen for intercomLauncher title change
        const observer = new MutationObserver((mutations) => {
            for (const mutation of mutations) {
                if (mutation.type === 'attributes' && mutation.attributeName === 'title') {
                    setTimeout(() => {
                        if (mutation.target.title == 'Open Intercom Messenger') {
                            messengerDiv.classList.remove('show');
                        } else {
                            messengerDiv.classList.add('show');
                        }
                    }, 200);
                }
            }
        });
        observer.observe(intercomLauncher, { attributes: true });

    });
</script>

