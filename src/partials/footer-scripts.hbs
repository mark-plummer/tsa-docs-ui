<script>
    function onIntercomMessengerFrame(callback) {
        const selector = 'div.intercom-messenger-frame';
        // Fast path: already in DOM
        const existing = document.querySelector(selector);
        if (existing) {
            callback(existing);
            return () => { };
        }
        const obs = new MutationObserver((mutations) => {
            for (const { addedNodes } of mutations) {
                for (const node of addedNodes) {
                    if (node.nodeType !== 1) continue;
                    const found =
                        node.matches?.(selector) ||
                        node.querySelector?.(selector);
                    if (found) {
                        obs.disconnect();
                        callback(found);
                        return;
                    }
                }
            }
        });
        obs.observe(document.documentElement, {
            childList: true,
            subtree: true,
        });
        return () => obs.disconnect(); // cleanup if never found
    }

    async function checkIntercomScript() {
        let messengerDiv = null;
        let overrideIntercomScript = true;

        async function hashString(input, algorithm = 'SHA-256') {
            const data = new TextEncoder().encode(input);
            const hashBuffer = await crypto.subtle.digest(algorithm, data);
            // hex token
            return [...new Uint8Array(hashBuffer)]
                .map(b => b.toString(16).padStart(2, '0'))
                .join('');
        }

        const intercomScriptHash = '1f1929966660988313523d346dd6dc3db4d74b43b857bd8f3ea33d4385bea22f'; // Generate with npm run hash_intercom
        const currentIntercomScript = await fetch('https://widget.intercom.io/widget/b4z6stjj');
        const currentIntercomScriptText = await currentIntercomScript.text();
        const currentIntercomScriptHash = await hashString(currentIntercomScriptText);

        console.log('currentIntercomScriptHash:', currentIntercomScriptHash, intercomScriptHash);

        if (currentIntercomScriptHash !== intercomScriptHash) {
            console.log('Intercom script has changed');
        } else {
            const style = document.createElement('style');
            style.innerHTML = `
                .intercom-namespace .intercom-app .intercom-messenger-frame {
                    height: 100vh!important;
                    max-height: 100vh!important;
                    min-height: 100vh!important;
                    top: 0!important;
                    right: 0!important;
                    border-radius: 24px 0 0 24px!important;
                    transform: translateX(100%)!important;
                    transition: transform .5s, box-shadow .5s, opacity .5s ease-out!important;
                    box-shadow: none!important;
                    visibility: visible!important;
                }

                .intercom-namespace .intercom-app .intercom-messenger-frame.show {
                    transform: translateX(0)!important;
                    box-shadow: rgba(9, 14, 21, 0.16) 0px 5px 40px 0px!important;
                }

                {{!-- Hide this element because it's used as a initializing animation for the messenger window and we're doing our own animation. --}}
                .intercom-messenger {
                    display: none!important;
                }
            `;
            document.body.appendChild(style);

            function showMessenger() {
                if (messengerDiv && overrideIntercomScript) {
                    setTimeout(() => {
                        messengerDiv.classList.add('show');
                    }, 100);
                }
            }

            Intercom('onShow', function () {
                // console.log('Intercom messenger opened');
                showMessenger();
            });

            onIntercomMessengerFrame((el) => {
                messengerDiv = el
                
                const computedStyle = getComputedStyle(messengerDiv);
                // Subset of computed styles to compare for changes
                const computedStyleString = computedStyle.position + computedStyle.top + computedStyle.right + computedStyle.bottom + computedStyle.left + computedStyle.width + computedStyle.height + computedStyle.borderRadius + computedStyle.transform + computedStyle.transition + computedStyle.boxShadow + computedStyle.visibility;
                console.log('computedStyleString:', computedStyleString);
                hashString(computedStyleString)
                .then(hash => {
                    // console.log('hash:', hash);
                    if (hash !== 'c3f299724918c64bba70e1ea228cfa4150719d428f7ab7b60b3cbf33425f6fe4') {
                        console.log('Intercom styles have changed.');
                        style.remove();
                        overrideIntercomScript = false;
                    } else {
                        showMessenger();
                    }
                });
            });
        }
    };
    checkIntercomScript();

</script>

